{
  "name": "@ludiars/schedula-sdk",
  "version": "0.1.0",
  "description": "Schedula Module SDK — declare modules with routes, WS commands, tables, and user data columns (backed by Cernere)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing.js",
      "types": "./dist/testing.d.ts"
    }
  },
  "files": ["dist", "src"],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.0",
    "hono": "^4.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.0.0",
    "typescript": "~5.9.3",
    "zod": "^4.3.6"
  },
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LUDIARS/Schedula.git",
    "directory": "packages/sdk"
  }
}
