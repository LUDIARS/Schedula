# ═══════════════════════════════════════════════════════════════
# Schedula — Docker 環境変数
# ═══════════════════════════════════════════════════════════════
#
# このファイルは通常 secrets-cli が自動生成します:
#   npm run secrets -- setup   → Infisical 認証設定
#   npm run secrets -- env     → Infisical → .env 生成
#
# Infisical を使わない場合は、このテンプレートをコピーして
# .env として使用してください:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ─── Infrastructure (Docker Compose 用) ──────────────────────
FRONTEND_PORT=8080
BACKEND_PORT=3000
DB_PORT=5432
REDIS_PORT=6379

DB_DIALECT=postgres
POSTGRES_USER=schedula
POSTGRES_PASSWORD=schedula
POSTGRES_DB=schedula

DATABASE_URL=postgresql://schedula:schedula@db:5432/schedula
REDIS_URL=redis://redis:6379

# ─── Infisical Bootstrap (使用時のみ) ────────────────────────
# SECRETS_PROVIDER=infisical
# INFISICAL_SITE_URL=https://app.infisical.com
# INFISICAL_PROJECT_ID=
# INFISICAL_ENVIRONMENT=dev
# INFISICAL_CLIENT_ID=
# INFISICAL_CLIENT_SECRET=

# ─── Runtime Secrets (Infisical 未使用時は直接設定) ───────────
# JWT_SECRET=change-me-in-production
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=
# FRONTEND_URL=
