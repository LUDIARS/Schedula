{
  "name": "actio",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "sdk:build": "cd packages/sdk && npx tsc",
    "predev": "npm run sdk:build",
    "dev": "npm run env:env && npx dotenv-cli -- concurrently -n api,web -c green,cyan \"tsx watch src/index.ts\" \"npx dotenv-cli -- npm run dev --prefix frontend\"",
    "predev:server": "npm run sdk:build",
    "dev:server": "npx dotenv-cli -- tsx watch src/index.ts",
    "dev:front": "npx dotenv-cli -- npm run dev --prefix frontend",
    "prebuild": "npm run sdk:build",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:init": "tsx src/db/migrate.ts",
    "redis:export": "tsx scripts/redis-export.ts",
    "redis:import": "tsx scripts/redis-import.ts",
    "db:export": "tsx scripts/db-export.ts",
    "db:import": "tsx scripts/db-import.ts",
    "env:setup": "npx tsx ../Cernere/packages/env-cli/src/cli.ts setup",
    "env:test": "npx tsx ../Cernere/packages/env-cli/src/cli.ts test",
    "env:env": "npx tsx ../Cernere/packages/env-cli/src/cli.ts env",
    "env:initialize": "npx tsx ../Cernere/packages/env-cli/src/cli.ts initialize",
    "env:list": "npx tsx ../Cernere/packages/env-cli/src/cli.ts list",
    "env:get": "npx tsx ../Cernere/packages/env-cli/src/cli.ts get",
    "env:set": "npx tsx ../Cernere/packages/env-cli/src/cli.ts set",
    "env:up": "npx tsx ../Cernere/packages/env-cli/src/cli.ts env && docker compose up -d",
    "env:up:prod": "npx tsx ../Cernere/packages/env-cli/src/cli.ts env && docker compose up -d",
    "env:up:standalone": "npx tsx ../Cernere/packages/env-cli/src/cli.ts env && docker compose -f docker-compose.yaml -f docker-compose.standalone.yaml up -d",
    "setup": "bash scripts/setup.sh",
    "ci-check": "bash scripts/ci-check.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "id:scan": "tsx services/id-service/src/migration/cli.ts",
    "id:service": "tsx services/id-service/src/server.ts"
  },
  "repository": {
    "type": "git",
    "url": "http://local_proxy@127.0.0.1:34017/git/LUDIARS/Schedula"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.1016.0",
    "@hono/node-server": "^1.19.11",
    "@hono/node-ws": "^1.3.0",
    "@ludiars/cernere-id-cache": "^0.1.0",
    "@ludiars/cernere-id-service": "^0.1.0",
    "@ludiars/cernere-service-adapter": "^0.2.2",
    "@ludiars/schedula-sdk": "^0.1.0",
    "@ludiars/schedula-module-voting": "^0.1.0",
    "@ludiars/schedula-module-holiday": "^0.1.0",
    "@ludiars/schedula-module-myplan": "^0.1.0",
    "@ludiars/schedula-module-smart-scheduler": "^0.1.0",
    "@ludiars/schedula-module-school": "^0.1.0",
    "@ludiars/schedula-module-integrations": "^0.1.0",
    "@ludiars/schedula-module-cocoiru": "^0.1.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "csv-parse": "^6.1.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0",
    "postgres": "^3.4.8",
    "uuid": "^13.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
